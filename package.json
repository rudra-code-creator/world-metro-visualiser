{
  "name": "world-metro-visualiser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "generate:geojson": "node scripts/generate-geojson.mjs",
    "build:manifest": "node scripts/build-manifest.mjs",
    "build:profiles": "node scripts/build-city-profiles.mjs",
    "fetch:metro": "node --max-old-space-size=4096 scripts/fetch-osm-metro.mjs"
  },
  "dependencies": {
    "mapbox-gl": "^3.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "adm-zip": "^0.5.17",
    "osmtogeojson": "^3.0.0-beta.5",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  }
}
